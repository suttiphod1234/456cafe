// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY_FOR_QC      // Added
  READY_FOR_PICKUP  // Added
  DISPATCHED        // Added
  READY             // Legacy, keeping for compat if needed but will use the others
  COMPLETED
  PICKED_UP
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String?
  address   String?
  latitude  Float?
  longitude Float?
  isOpen    Boolean  @default(true)
  openTime  String?
  closeTime String?
  orders    Order[]
  inventory Inventory[]
  managers  BranchManager[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchManager {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  name      String
  email     String?
  phone     String?
  role      String   @default("BRANCH_MANAGER")
  lineUid   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  icon        String?   // emoji or icon name
  imageUrl    String?
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id           String            @id @default(uuid())
  name         String
  description  String?
  price        Float
  categoryId   String?
  category     Category?         @relation(fields: [categoryId], references: [id])
  imageUrl     String?
  status       String            @default("AVAILABLE") // AVAILABLE | OUT_OF_STOCK | HIDDEN
  tags         String            @default("[]")        // JSON: ["Bestseller","New"]
  sortOrder    Int               @default(0)
  optionGroups MenuOptionGroup[]
  recipes      Recipe[]
  orderItems   OrderItem[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model MenuOptionGroup {
  id         String       @id @default(uuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id])
  name       String       // e.g., "เลือก Size", "ความหวาน"
  isRequired Boolean      @default(false)
  maxSelect  Int          @default(1)
  sortOrder  Int          @default(0)
  options    MenuOption[]
}

model MenuOption {
  id         String          @id @default(uuid())
  groupId    String
  group      MenuOptionGroup @relation(fields: [groupId], references: [id])
  label      String          // e.g., "S", "M", "L"
  priceAddon Float           @default(0)
  isDefault  Boolean         @default(false)
  sortOrder  Int             @default(0)
}

model Ingredient {
  id            String   @id @default(uuid())
  name          String
  unit          String   // e.g., "ml", "g", "pcs"
  inventory     Inventory[]
  recipeItems   Recipe[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Inventory {
  id           String     @id @default(uuid())
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  lowStockThreshold Float @default(100)
  updatedAt    DateTime   @updatedAt

  @@unique([branchId, ingredientId])
}

model Recipe {
  id           String     @id @default(uuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float      // Amount required per product
}

model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique @default(uuid()) // human-friendly order number
  branchId        String
  branch          Branch      @relation(fields: [branchId], references: [id])
  userId          String?     // Optional: Link to a registered User
  user            User?       @relation(fields: [userId], references: [id])
  customerUid     String      // Legacy/Guest identification (LINE UID or random)
  customerName    String?
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  fulfillmentType String      @default("PICKUP") // PICKUP | DELIVERY
  note            String?     // special instructions
  platform        String      @default("STORE")  // STORE | LINE | GRAB | FOODPANDA
  riderName       String?
  riderPhone      String?
  qcNote          String?
  scheduledAt     DateTime?   // pre-order pickup time
  queueNo         Int         @default(0) // Added
  items           OrderItem[]
  payment         Payment?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model User {
  id              String         @id @default(uuid())
  name            String?
  email           String?        @unique
  phone           String?        @unique
  points          Int            @default(0)
  role            String         @default("CUSTOMER") // CUSTOMER | ADMIN
  authProviders   AuthProvider[]
  orders          Order[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model AuthProvider {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  provider    String   // LINE | GOOGLE | PHONE
  providerId  String   @unique // The unique ID from the provider (e.g. LINE UID)
  createdAt   DateTime @default(now())
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(1)
  unitPrice     Float    // base menu price at time of order
  optionsPrice  Float    @default(0) // total addon price
  price         Float    // final: (unitPrice + optionsPrice) * quantity
  productName   String?  // snapshot: name at order time
  customization Json?    // { sweetness: "50%", milk: "oat", size: "L" }
  selectedOptions Json?  // snapshot: [{ group: "Size", label: "L", priceAddon: 20 }]
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  amount        Float
  status        PaymentStatus @default(UNPAID)
  method        String        @default("CASH") // CASH | QR | TRANSFER | ONLINE
  transactionId String?
  qrPayload     String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String?  // Optional: User who performed the action
  details   Json?
  createdAt DateTime @default(now())
}
